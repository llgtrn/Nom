# Build artifacts
nom-compiler/target/
nom-compiler/target2/
*.exe
*.nomiz
# LLVM build outputs produced by `nom build --target llvm` — never
# checked in; deterministic from the corresponding .nom source.
*.bc
*.ll

# Database files (10M+ nomtu dictionary, too large for git)
data/
*.db
*.db-shm
*.db-wal
# Exception: the canonical grammar baseline ships as a small SQL data
# file alongside the nom-grammar crate. Allow it through the data/
# block above.
!nom-compiler/crates/nom-grammar/data/
!nom-compiler/crates/nom-grammar/data/*.sql

# Nom build output
.nom-out/

# IDE / editor
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# OMC state
.omx/

# Claude state
.claude/

# Precompiled .bc output
.nom-bc/

# Additional build artifacts  
nom-compiler/.nom-out/
*.nomiz
.gitnexus
